rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if owns(uid);
      allow create, update: if owns(uid)
        && request.resource.data.keys().hasOnly([
          'name', 'email', 'unlockedLevelIndex', 'coins', 'premium',
          'routeJokers', 'breakerJokers', 'keyJokers', 'updatedAt'
        ]);
      allow delete: if owns(uid);
    }

    match /leaderboard/{entryId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid', 'name', 'score', 'level', 'levelIndex', 'moves', 'durationMs',
          'period', 'periodKey', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.score is int
        && request.resource.data.levelIndex is int
        && request.resource.data.moves is int
        && request.resource.data.durationMs is int
        && request.resource.data.period in ['daily', 'weekly', 'monthly'];
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /leaderboardGlobal/{bucket}/entries/{entryId} {
      allow read: if true;
      allow create, update: if signedIn()
        && entryId == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid', 'name', 'totalScore', 'plays', 'lastScore', 'lastLevel',
          'lastLevelIndex', 'lastMoves', 'lastDurationMs', 'period',
          'periodKey', 'updatedAt'
        ])
        && request.resource.data.totalScore is int
        && request.resource.data.plays is int
        && request.resource.data.lastScore is int
        && request.resource.data.lastLevelIndex is int
        && request.resource.data.lastMoves is int
        && request.resource.data.lastDurationMs is int
        && request.resource.data.period in ['daily', 'weekly', 'monthly'];
      allow delete: if signedIn()
        && entryId == request.auth.uid
        && resource.data.uid == request.auth.uid;
    }

    match /arenaRooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'hostUid', 'hostName', 'guestUid', 'guestName', 'levelIndex',
          'hostScore', 'guestScore', 'createdAt', 'updatedAt'
        ]);
      allow update: if signedIn()
        && (
          resource.data.hostUid == request.auth.uid
          || resource.data.guestUid == request.auth.uid
          || request.resource.data.guestUid == request.auth.uid
        )
        && request.resource.data.keys().hasOnly([
          'hostUid', 'hostName', 'guestUid', 'guestName', 'levelIndex',
          'hostScore', 'guestScore', 'createdAt', 'updatedAt'
        ]);
      allow delete: if signedIn()
        && (
          resource.data.hostUid == request.auth.uid
          || resource.data.guestUid == request.auth.uid
        );
    }
  }
}
